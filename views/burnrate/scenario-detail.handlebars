    <!-- Scenario Navigation JavaScript -->
    <script>
    (function() {
        'use strict';

        // Scenario navigation order
        const scenarios = [
            'ScA_Baseline',
            'ScA_NoTrust',
            'ScA_MAPT'
        ];

        const currentScenarioId = '{{scenario.id}}';
        const currentIndex = scenarios.indexOf(currentScenarioId);

        // Navigate to previous scenario
        $('#prevScenario').on('click', function() {
            if (currentIndex > 0) {
                const prevScenario = scenarios[currentIndex - 1];
                window.location.href = '/BurnRate/scenario/' + prevScenario;
            }
        });

        // Navigate to next scenario
        $('#nextScenario').on('click', function() {
            if (currentIndex < scenarios.length - 1) {
                const nextScenario = scenarios[currentIndex + 1];
                window.location.href = '/BurnRate/scenario/' + nextScenario;
            }
        });

        // Disable buttons at boundaries
        if (currentIndex === 0) {
            $('#prevScenario').prop('disabled', true).css('opacity', '0.3');
        }
        if (currentIndex === scenarios.length - 1) {
            $('#nextScenario').prop('disabled', true).css('opacity', '0.3');
        }

        // Keyboard navigation (left/right arrows)
        $(document).on('keydown', function(e) {
            if (e.key === 'ArrowLeft' && currentIndex > 0) {
                $('#prevScenario').click();
            } else if (e.key === 'ArrowRight' && currentIndex < scenarios.length - 1) {
                $('#nextScenario').click();
            }
        });

        // Make sticky nav visible on scroll
        $(window).on('scroll', function() {
            const sticky = $('#scenarioNavSticky');
            if ($(window).scrollTop() > 100) {
                sticky.addClass('visible');
            } else {
                sticky.removeClass('visible');
            }
        });
    })();
    </script>

