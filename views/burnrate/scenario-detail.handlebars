    <div class="container">
        <div class="header-bar" style="margin-bottom: 8px; padding-bottom: 8px;">
            <h1 style="font-size: 1.3em;">BurnRate Financial Planning</h1>
        </div>

        <!-- Sticky Scenario Navigation -->
        <div class="scenario-nav-sticky" id="scenarioNavSticky">
            <div class="scenario-nav-content">
                <a href="/BurnRate/" class="nav-back-link">&larr; Back to Scenarios</a>
                <div class="scenario-nav-controls">
                    <button class="nav-arrow" id="prevScenario" title="Previous scenario">&larr;</button>
                    <h2 class="scenario-nav-title">{{scenario.name}}</h2>
                    <button class="nav-arrow" id="nextScenario" title="Next scenario">&rarr;</button>
                </div>
            </div>
        </div>

        <div style="margin-bottom: 5px;">
            <a href="/BurnRate/" style="color: #66ccff; text-decoration: none; font-size: 13px;">&larr; Back to Scenarios</a>
        </div>

        <h1 style="color: #66ccff; margin: 0 0 4px 0; font-size: 1.4em;">{{scenario.name}}</h1>
        <p style="color: #999; margin: 0 0 10px 0; font-size: 0.9em;">{{scenario.description}}</p>

<div>

    {{#if outcome}}
    <div style="padding: 15px; margin-bottom: 10px; background: #2a2a2a; border-left: 4px solid #66ccff;">
        <h3 style="margin: 0 0 10px 0; color: #66ccff;">Outcome Summary</h3>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px 30px; color: #dcdcdc; font-size: 14px;">
            <!-- LEFT COLUMN -->
            <div>
                <table id="outcomeSummaryTable" style="border-collapse:collapse;font-size:14px;">
                    <tr><td style="font-weight:bold;padding:2px 8px 2px 0;vertical-align:top;" rowspan="2">Lifestyle:</td><td style="padding:2px 8px;">Cost of living:</td><td style="padding:2px 0;"><span style="color:#27ae60;">${{formatNumber (multiply (or scenario.lifestyle_floor_monthly 2500) 12)}}/yr</span> (${{or scenario.lifestyle_floor_monthly 2500}}/mo)</td></tr>
                    <tr><td style="padding:2px 8px;">Tithe:</td><td style="padding:2px 0;"><span style="color:#27ae60;">${{formatNumber (multiply (or scenario.charitable_monthly 0) 12)}}/yr</span> (${{or scenario.charitable_monthly 0}}/mo)</td></tr>
                    <tr><td colspan="3" style="padding:3px 0;"></td></tr>
                    <tr><td style="font-weight:bold;padding:2px 8px 2px 0;vertical-align:top;" rowspan="4">Total Tax &amp; IRMAA:</td><td style="padding:2px 8px;">State</td><td style="padding:2px 0;">${{formatNumber outcome.total_state_tax}}</td></tr>
                    <tr><td style="padding:2px 8px;">Fed</td><td style="padding:2px 0;">${{formatNumber outcome.total_federal_tax}}</td></tr>
                    <tr><td style="padding:2px 8px;">IRMAA</td><td style="padding:2px 0;" id="totalIrmaaSummary">$0</td></tr>
                    {{#if outcome.total_capital_gains_tax}}
                    <tr><td style="padding:2px 8px;">Cap Gains</td><td style="padding:2px 0; color: #e74c3c;">${{formatNumber outcome.total_capital_gains_tax}}</td></tr>
                    {{/if}}
                </table>
            </div>
            <!-- RIGHT COLUMN -->
            <div>
                <div style="margin-bottom:6px;"><strong>IRA Depleted:</strong>
                    {{#if outcome.ira_depleted_year}}
                        {{#compare scenario.condo_disposition 'trust_mapt' operator='==='}}
                            {{#compare outcome.ira_depleted_year annotations.medicaid_trigger_year operator='==='}}
                                <span style="color: #27ae60; font-weight: bold;">${{formatNumber annotations.snt_funded_amount}} preserved for protected spending ({{outcome.ira_depleted_year}})</span>
                            {{else}}
                                {{#compare outcome.ira_depleted_year annotations.medicaid_trigger_year operator='<'}}
                                    <span style="color: #e74c3c; font-weight: bold;">{{outcome.ira_depleted_year}} — depleted before protection activation</span>
                                {{else}}
                                    <span>{{outcome.ira_depleted_year}}</span>
                                {{/compare}}
                            {{/compare}}
                        {{else}}
                            <span style="color: #f39c12;">{{outcome.ira_depleted_year}}</span>
                        {{/compare}}
                    {{else}}
                        <span style="color: #27ae60;">Never (sustainable)</span>
                    {{/if}}
                </div>
                <div style="margin-bottom:6px;"><strong>Real Estate tapped (HELOC or sale):</strong> {{#if outcome.real_estate_liquidated}}${{formatNumber outcome.real_estate_liquidated}}{{else}}<span style="color: #95a5a6;">$0</span>{{/if}}</div>
                <div><strong>Asset Depletion Risk:</strong>
                    {{#compare outcome.asset_depletion_risk 'red' operator='==='}}
                        {{#compare scenario.condo_disposition 'trust_mapt' operator='==='}}
                            <span style="color: #e74c3c; font-weight: bold;">🛑 DANGER — IRA depleted before the protection window begins. Care continuity is at risk.</span>
                        {{else}}
                            <span style="color: #e74c3c; font-weight: bold;">🛑 DANGER — IRA depleted during memory care. Real estate liquidation required to fund remaining care.</span>
                        {{/compare}}
                    {{else}}
                        {{#compare outcome.asset_depletion_risk 'magenta' operator='==='}}
                            <span style="color: #27ae60; font-weight: bold;">✓ Protection strategy successful</span>
                        {{else}}
                            {{#compare outcome.asset_depletion_risk 'yellow' operator='==='}}
                                <span style="color: #f39c12; font-weight: bold;">⚠️ Tight — may not sustain through memory care</span>
                            {{else}}
                                {{#compare outcome.asset_depletion_risk 'cyan' operator='==='}}
                                    <span style="color: #66ccff; font-weight: bold;">ℹ️ Minor asset depletion risk</span>
                                {{else}}
                                    <span style="color: #27ae60;">✓ No risk</span>
                                {{/compare}}
                            {{/compare}}
                        {{/compare}}
                    {{/compare}}
                </div>
            </div>
        </div>
    </div>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        var pd = window.projectionData;
        var od = window.optimizerData;
        var sc = window.scenarioConfig;

        // Total IRMAA (always compute, regardless of optimizer)
        if (pd) {
            var totalIrmaa = 0;
            for (var i = 0; i < pd.length; i++) {
                if (!pd[i].irmaa_self_funding) {
                    totalIrmaa += (pd[i].expenses && (pd[i].expenses.irmaa_gross || pd[i].expenses.irmaa)) || 0;
                }
            }
            var irmaaEl = document.getElementById('totalIrmaaSummary');
            if (irmaaEl) irmaaEl.textContent = '$' + Math.round(totalIrmaa).toLocaleString('en-US');
        }

        // Intensify year for MC facility search
        if (sc) {
            var ltcTrigger = sc.ltc_trigger_year || 2028;
            var mcYr = sc.memory_care_year || 2032;
            var intensifyYr = ltcTrigger + Math.floor((mcYr - ltcTrigger) / 2);
            var intEl = document.getElementById('intensifyYearLabel');
            if (intEl) intEl.textContent = '~' + intensifyYr + ':';
        }

        // AD survival probability for planning horizon
        var survEl = document.getElementById('survivalPctDecision');
        if (survEl && sc) {
            // MCI with cognitive reserves survival table (diagnosis 2026)
            var diagnosisYear = 2026;
            var horizonYear = sc.year_of_passing || 2040;
            var yearsPost = horizonYear - diagnosisYear;
            // From AD-actuarial-survival-data.md, mci_with_reserves table
            var survTable = {0:1.00,1:0.98,2:0.97,3:0.94,4:0.89,5:0.84,6:0.76,7:0.64,8:0.50,9:0.39,10:0.30,11:0.20,12:0.12,13:0.07,14:0.04,15:0.02,16:0.01};
            var prob = survTable[yearsPost] !== undefined ? survTable[yearsPost] : (yearsPost > 16 ? 0.005 : 1.0);
            survEl.innerHTML = 'AD actuarial: <span style="color:#f39c12;">' + (prob * 100).toFixed(0) + '% chance</span> of exceeding this horizon';
        }

        if (!pd || !od || !sc || !sc.optimizer_enabled) return;

        var startYear = pd[0] ? pd[0].year : 2026;
        var mcYear = sc.memory_care_year || 2032;
        var fiveYearEnd = startYear + 5;
        var saved5 = 0, savedMC = 0, savedTotal = 0;

        for (var i = 0; i < pd.length; i++) {
            var y = pd[i];
            if (!y.optimizer) continue;
            var s = y.optimizer.taxSaved || 0;
            savedTotal += s;
            if (y.year < fiveYearEnd) saved5 += s;
            if (y.year < mcYear) savedMC += s;
        }

        var fmt = function(n) { return '$' + Math.round(Math.abs(n)).toLocaleString('en-US'); };
        var sign = function(n) { return n >= 0 ? fmt(n) : '-' + fmt(n); };

        var tbl = document.getElementById('outcomeSummaryTable');
        if (!tbl) return;
        var p = 'style="padding:2px 8px;"';
        var spacer = '<tr><td colspan="3" style="padding:3px 0;"></td></tr>';
        var row = function(label, val) {
            return '<tr><td ' + p + '>' + label + '</td><td style="padding:2px 0;">' + sign(val) + '</td></tr>';
        };
        tbl.innerHTML += spacer +
            '<tr><td style="font-weight:bold;padding:2px 8px 2px 0;vertical-align:top;" rowspan="3">Optimizer Savings:</td><td ' + p + '>In 5 years:</td><td style="padding:2px 0;">' + sign(saved5) + '</td></tr>' +
            row('Until Memory Care:', savedMC) +
            row('Thru Medicaid:', savedTotal);
    });
    </script>
    {{/if}}

    {{#if projections}}
        <div class="projection-table-wrapper">
                <table class="projection-table" id="projectionTable" style="width: 100%; margin-top: 0; font-size: 14px;">
                    <thead>
                        <tr>
                            <th class="debug-col" rowspan="2" style="width: 20px; min-width: 20px; max-width: 20px; padding: 0; border: none; background: #1a1a1a;"></th>
                            <th colspan="5" class="section-header" style="background: #34495e; color: white; padding: 15px; font-size: 16px; font-weight: bold; text-align: center; border: 1px solid #2c3e50;">Assets</th>
                            <th colspan="{{#compare scenario.condo_disposition 'trust_mapt' operator='==='}}6{{else}}5{{/compare}}" class="section-header" style="background: #34495e; color: white; padding: 15px; font-size: 16px; font-weight: bold; text-align: center; border: 1px solid #2c3e50;">Cash Flow</th>
                        </tr>
                        <tr style="background: #34495e; color: white;">
                            <!-- Left: Assets -->
                            <th style="padding: 12px; text-align: left; border: 1px solid #2c3e50; width: 7%;">Year (Age)</th>
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 15%;">Real Estate (+appreciation) <span class="info-icon">ⓘ</span></th>
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 13%;">IRA Open | Close <span class="info-icon">ⓘ</span></th>
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 9%;">LTC Savings <span class="info-icon">ⓘ</span></th>
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; border-right: 3px solid #2c3e50; width: 11%;">Total Assets</th>

                            <!-- Right: Cash Flow -->
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 9%;">Income (taxable) <span class="info-icon">ⓘ</span></th>
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 9%;">Tax Deductions <span class="info-icon">ⓘ</span></th>
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 9%;">Base Expenses <span class="info-icon">ⓘ</span></th>
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 9%;">Budget (Lifestyle) <span class="info-icon">ⓘ</span></th>
                            {{#compare scenario.condo_disposition 'trust_mapt' operator='==='}}
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 12%;">MAPT Net <span class="info-icon">ⓘ</span></th>
                            {{/compare}}
                            <th style="padding: 12px; text-align: right; border: 1px solid #2c3e50; width: 9%;">Net Cashflow <span class="info-icon">ⓘ</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each projections}}
                        <tr data-year="{{this.year}}" style="background: {{#if @index}}#2a2a2a{{else}}#333{{/if}}; color: #dcdcdc;">
                            <!-- Debug info button -->
                            <td class="debug-cell" style="padding: 0; border: none; background: #1a1a1a; text-align: center; vertical-align: middle;">
                                <button class="debug-btn" data-year="{{this.year}}" style="background: none; border: none; color: #1a1a1a; cursor: pointer; font-size: 14px; width: 100%; padding: 4px 0;">&#9432;</button>
                            </td>
                            <!-- Year (Age) -->
                            <td style="padding: 10px; border: 1px solid #444;">{{this.year}} ({{this.age_a}})</td>

                            <!-- Real Estate -->
                            <td class="real-estate-cell" style="padding: 10px; text-align: right; border: 1px solid #444; cursor: help;"
                                title="{{formatRealEstateTooltip this}}">
                                ${{formatNumber this.real_estate_total}} (+${{formatNumber (add this.house_appreciation this.condo_appreciation)}})
                            </td>

                            <!-- IRA Open | Close -->
                            <td class="ira-cell" style="padding: 10px; text-align: right; border: 1px solid #444; cursor: help;"
                                title="{{formatIraTooltip this}}">
                                ${{formatNumber this.total_ira_open}} | ${{formatNumber this.total_ira_close}}
                            </td>

                            <!-- LTC Savings -->
                            <td class="ltc-cell" style="padding: 10px; text-align: right; border: 1px solid #444; cursor: help;"
                                title="{{formatLtcTooltip this}}">
                                ${{formatNumber this.ltc_savings_close}}
                            </td>

                            <!-- Total Assets -->
                            <td class="total-assets" style="padding: 10px; text-align: right; border: 1px solid #444; border-right: 3px solid #444; font-weight: bold; background: #3a3a3a; color: #66ccff;">
                                ${{formatAssets (add this.total_ira_close this.real_estate_total this.ltc_savings_close)}}
                            </td>

                            <!-- Income (taxable) - AGI and Taxable Income after deductions -->
                            <td class="taxable-income-cell" style="padding: 10px; text-align: right; border: 1px solid #444; color: #95a5a6; cursor: help;"
                                title="{{formatTaxableIncomeTooltip this}}">
                                ${{formatNumber this.agi}} (${{formatNumber (subtract this.agi this.deduction_amount)}})
                            </td>

                            <!-- Tax Deductions -->
                            <td class="deductions-cell" style="padding: 10px; text-align: right; border: 1px solid #444; color: #f39c12; cursor: help;"
                                title="{{formatDeductionsTooltip this}}">
                                {{{formatDeductionDisplay this}}}
                            </td>

                            <!-- Base Expenses (primary household only — expenses.total already excludes protection-trust expenses) -->
                            <td class="expenses-cell" style="padding: 10px; text-align: right; border: 1px solid #444; color: #e74c3c; cursor: help;"
                                title="{{formatExpensesTooltip this.expenses this}}">
                                ${{formatNumber this.expenses.total}} ({{countItems this.expenses}})
                            </td>

                            <!-- Personal Budget (Lifestyle) -->
                            <td class="budget-cell" style="padding: 10px; text-align: right; border: 1px solid #444; color: #27ae60; cursor: help;"
                                title="{{formatIncomeTooltip this.income this}}">
                                {{#if this.in_memory_care}}
                                    ${{formatNumber this.personA_lifestyle_extras}} ($0)
                                {{else}}
                                    ${{formatNumber this.personal_budget}} (${{formatNumber this.expenses.lifestyle}})
                                {{/if}}
                            </td>

                            <!-- MAPT Net (Trust Income - Trust Expenses - Balance) — MAPT only -->
                            {{#compare ../scenario.condo_disposition 'trust_mapt' operator='==='}}
                            <td class="mapt-net-cell" style="padding: 10px; text-align: right; border: 1px solid #444; cursor: help; font-size: 0.85em; white-space: nowrap;"
                                title="{{formatMaptTooltip this}}">
                                {{#if this.trust_gross_income}}
                                    <span style="color: #27ae60;">${{formatNumber1d this.trust_gross_income}}</span>
                                    <span style="color: #e74c3c;"> -${{formatNumber1d (or this.mapt_property_expenses 0)}}</span><br>
                                    <span style="color: #888;">={{formatNumber1d (subtract this.trust_gross_income (or this.mapt_property_expenses 0))}} + </span><span style="color: #66ccff;">${{formatNumber1d (or this.mapt_checking_open 0)}}</span><br>
                                    <span style="color: #66ccff; font-weight: bold;">${{formatNumber1d this.trust_balance}}</span>
                                {{else}}
                                    {{#if this.mapt_property_expenses}}
                                        <span style="color: #e74c3c;">-${{formatNumber1d this.mapt_property_expenses}}</span><br>
                                        <span style="color: #888;">-${{formatNumber1d this.mapt_property_expenses}} + </span><span style="color: #66ccff;">${{formatNumber1d (or this.mapt_checking_open 0)}}</span><br>
                                        <span style="color: #66ccff; font-weight: bold;">${{formatNumber1d this.trust_balance}}</span>
                                    {{else}}
                                        <span style="color: #555;">—</span>
                                    {{/if}}
                                {{/if}}
                            </td>
                            {{/compare}}

                            <!-- Net Cashflow (Budget - Expenses) -->
                            <td class="net-cashflow" style="padding: 10px; text-align: right; border: 1px solid #444; font-weight: bold; cursor: help;"
                                title="{{formatNetCashflowTooltip this.income this.expenses this}}">
                                ${{formatNumber (add this.income.total (multiply this.expenses.total -1))}}
                            </td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>

