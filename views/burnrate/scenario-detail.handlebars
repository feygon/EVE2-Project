        {{#if annotations}}
        <script>
        (function() {
            'use strict';
            var annotations = {{{json annotations}}};

            function placeAnnotations() {
                var table = document.getElementById('projectionTable');
                if (!table) return;

                // Annotations on body — positioned in page coordinates
                // Hidden below 1440px via CSS media query (annotations overlap at narrow widths)
                document.body.style.position = 'relative';

                var annotDiv = document.getElementById('bodyAnnotations');
                if (!annotDiv) {
                    annotDiv = document.createElement('div');
                    annotDiv.id = 'bodyAnnotations';
                    document.body.appendChild(annotDiv);
                }
                annotDiv.innerHTML = '';

                var container = table.closest('.container');
                if (!container) return;
                // Anchor annotations to the table's actual right edge
                var tableRect = table.getBoundingClientRect();
                var tableRight = tableRect.left + window.scrollX + table.scrollWidth;
                var containerRight = container.getBoundingClientRect().right + window.scrollX;
                var annotAnchor = Math.max(tableRight, containerRight); // whichever is further right
                var annotLeft = annotAnchor + 15;

                var rows = table.querySelectorAll('tbody tr[data-year]');
                var rowMap = {};
                rows.forEach(function(row) {
                    var year = parseInt(row.getAttribute('data-year'), 10);
                    rowMap[year] = row;
                });

                // Page-level Y coordinates (account for scroll)
                function getRowCenter(year) {
                    var row = rowMap[year];
                    if (!row) return null;
                    var rect = row.getBoundingClientRect();
                    return rect.top + window.scrollY + (rect.height / 2);
                }

                function getRowTop(year) {
                    var row = rowMap[year];
                    if (!row) return null;
                    return row.getBoundingClientRect().top + window.scrollY;
                }

                function getRowBottom(year) {
                    var row = rowMap[year];
                    if (!row) return null;
                    return row.getBoundingClientRect().bottom + window.scrollY;
                }

                // Magenta care brackets (just inside the table's right edge)
                var magentaLeft = annotAnchor - 8;

                // At-Home Care bracket: LTC trigger → memory care (with midline at bottom)
                if (annotations.ltc_trigger_year && annotations.memory_care_year) {
                    var ahTop = getRowTop(annotations.ltc_trigger_year);
                    var ahBottom = getRowTop(annotations.memory_care_year);
                    if (ahTop !== null && ahBottom !== null && ahBottom > ahTop) {
                        var el = document.createElement('div');
                        el.className = 'care-bracket care-bracket-top care-bracket-midline';
                        el.style.top = ahTop + 'px';
                        el.style.height = (ahBottom - ahTop) + 'px';
                        el.style.left = magentaLeft + 'px';
                        annotDiv.appendChild(el);
                    }
                }

                // Memory Care bracket: memory care → year of passing
                if (annotations.memory_care_year && annotations.year_of_passing) {
                    var mcTop = getRowTop(annotations.memory_care_year);
                    var mcBottom = getRowBottom(annotations.year_of_passing);
                    if (mcTop !== null && mcBottom !== null) {
                        var el = document.createElement('div');
                        el.className = 'care-bracket care-bracket-bottom';
                        el.style.top = mcTop + 'px';
                        el.style.height = (mcBottom - mcTop) + 'px';
                        el.style.left = magentaLeft + 'px';
                        annotDiv.appendChild(el);
                    }
                }

                // Collect all arrow annotations with their target year
                var arrowDefs = [];

                function addArrow(year, color, text, title, interactive) {
                    var y = getRowTop(year);
                    if (y !== null) arrowDefs.push({ year: year, targetY: y, color: color, text: text, title: title || null, interactive: !!interactive });
                }

                if (annotations.trust_formation_year)
                    addArrow(annotations.trust_formation_year, '#66ccff', 'Trust formed \u2014 lookback clock starts');

                if (annotations.condo_sale_year) {
                    var proceeds = annotations.condo_sale_proceeds ? '$' + annotations.condo_sale_proceeds.toLocaleString() : 'unknown';
                    addArrow(annotations.condo_sale_year, '#f39c12', 'Investment property sold',
                        'support property sold for ' + proceeds + '.', true);
                }

                if (annotations.nursing_intensify_year) {
                    var lowK = '$' + (annotations.nursing_low_cost / 1000).toLocaleString() + 'k';
                    var highK = '$' + (annotations.nursing_high_cost / 1000).toLocaleString() + 'k';
                    addArrow(annotations.nursing_intensify_year, '#e74c3c',
                        'At-home nursing intensifies (' + highK + '/yr) \u24D8',
                        'Transitions from ' + lowK + '/yr to ' + highK + '/yr.', true);
                }

                if (annotations.lookback_clear_year)
                    addArrow(annotations.lookback_clear_year, '#27ae60', '5-year review window clears \u2014 assets protected');

                if (annotations.crisis_pivot_ready && annotations.lookback_clear_year)
                    addArrow(annotations.lookback_clear_year, '#e91e63', 'Crisis pivot ready');

                if (annotations.memory_care_year)
                    addArrow(annotations.memory_care_year, '#cc44aa', 'Memory Care begins \u24D8',
                        'Choose carefully: transferring facilities mid-care is hazardous. Select one that can continue the long-term coverage path.', true);

                if (annotations.medicaid_pre_liquidation_year) {
                    var sntAmount = annotations.snt_funded_amount ? '$' + Math.round(annotations.snt_funded_amount).toLocaleString() : 'unknown';
                    addArrow(annotations.medicaid_pre_liquidation_year, '#f39c12',
                        'Pre-protection IRA liquidation starts in December (tax strategy) \u24D8',
                        'Strategic liquidation split across two tax years. All proceeds (' + sntAmount + ') move into the protected support trust.', true);
                }

                if (annotations.cash_depleted_year) {
                    var resultMsg = '';
                    if (annotations.cash_depleted_result === 'medicaid_begins') {
                        var nYears = annotations.years_in_memory_care_at_depletion;
                        var suffix = nYears !== null ? ' after ' + nYears + ' yr' + (nYears !== 1 ? 's' : '') + ' in memory care' : '';
                        resultMsg = 'coverage transition begins' + suffix;
                    } else if (annotations.cash_depleted_result === 'real_estate_liquidation_imminent') {
                        resultMsg = 'Partial real estate liquidation imminent';
                    }
                    addArrow(annotations.cash_depleted_year, '#e74c3c',
                        'Cash Depleted \u2014 ' + resultMsg + ' \u24D8',
                        'Coverage transition requires countable assets below the protected threshold.', true);
                }

                if (annotations.medicaid_trigger_year)
                    addArrow(annotations.medicaid_trigger_year, '#e74c3c',
                        'Coverage invoked \u2014 full liquidation \u2192 support trust \u24D8',
                        'All financial instruments liquidated and moved into the protected support trust. Institutional coverage takes over care costs.', true);

                if (annotations.roommate_start_year)
                    addArrow(annotations.roommate_start_year, '#27ae60',
                        'support-household roommate income begins ($' + (annotations.roommate_monthly || 0).toLocaleString() + '/mo) \u24D8',
                        'Roommate rent flows to the protection trust checking account to help cover property expenses after the primary household moves to memory care.', true);

                // Sort by year, then by insertion order within same year
                arrowDefs.sort(function(a, b) { return a.year - b.year; });
                if (arrowDefs.length === 0) return;

                // Group by year
                var yearGroups = [];
                var curGroup = null;
                arrowDefs.forEach(function(def) {
                    if (!curGroup || curGroup.year !== def.year) {
                        curGroup = { year: def.year, rowY: def.targetY, labels: [] };
                        yearGroups.push(curGroup);
                    }
                    curGroup.labels.push(def);
                });

                // Create label elements (hidden for measurement)
                var labelX = annotLeft + 18;
                yearGroups.forEach(function(group) {
                    group.elements = [];
                    group.labels.forEach(function(def) {
                        var el = document.createElement('div');
                        el.className = 'annotation-label';
                        el.style.position = 'absolute';
                        el.style.left = labelX + 'px';
                        el.style.top = '0px';
                        el.style.width = '300px';
                        el.style.visibility = 'hidden';
                        el.style.fontSize = '13px';
                        el.style.fontWeight = 'bold';
                        el.style.lineHeight = '1.3';
                        el.style.color = def.color;
                        el.textContent = def.text;
                        if (def.interactive) el.style.cursor = 'help';
                        if (def.title) el.title = def.title;
                        annotDiv.appendChild(el);
                        group.elements.push(el);
                    });
                });

                // Measure heights, compute positions, draw leader lines
                requestAnimationFrame(function() {
                    yearGroups.forEach(function(group) {
                        group.heights = group.elements.map(function(el) { return el.offsetHeight + 2; });
                        group.totalHeight = group.heights.reduce(function(a, b) { return a + b; }, 0);
                    });

                    // Create SVG overlay for leader lines
                    var svgNS = 'http://www.w3.org/2000/svg';
                    var svg = document.createElementNS(svgNS, 'svg');
                    svg.style.position = 'absolute';
                    svg.style.left = '0';
                    svg.style.top = '0';
                    svg.style.width = document.documentElement.scrollWidth + 'px';
                    svg.style.height = document.documentElement.scrollHeight + 'px';
                    svg.style.pointerEvents = 'none';
                    svg.style.zIndex = '1';
                    annotDiv.appendChild(svg);

                    function line(x1, y1, x2, y2, color, width) {
                        var l = document.createElementNS(svgNS, 'line');
                        l.setAttribute('x1', x1); l.setAttribute('y1', y1);
                        l.setAttribute('x2', x2); l.setAttribute('y2', y2);
                        l.setAttribute('stroke', color || '#888');
                        l.setAttribute('stroke-width', width || 1.5);
                        svg.appendChild(l);
                    }

                    function circle(cx, cy, r, color) {
                        var c = document.createElementNS(svgNS, 'circle');
                        c.setAttribute('cx', cx); c.setAttribute('cy', cy);
                        c.setAttribute('r', r);
                        c.setAttribute('fill', color || '#888');
                        svg.appendChild(c);
                    }

                    var channelX = annotLeft + 8;  // vertical channel for leader lines
                    var cursor = yearGroups[0].rowY;

                    yearGroups.forEach(function(group) {
                        var rowMid = group.rowY + 12;
                        var labelsY = Math.max(cursor, rowMid);

                        // Position each label
                        var y = labelsY - 5;
                        for (var i = 0; i < group.elements.length; i++) {
                            group.elements[i].style.top = y + 'px';
                            group.elements[i].style.visibility = 'visible';
                            y += group.heights[i];
                        }

                        // Measure each label's vertical midpoint (first line of text)
                        var labelMids = [];
                        for (var i = 0; i < group.elements.length; i++) {
                            var el = group.elements[i];
                            var elTop = parseFloat(el.style.top);
                            labelMids.push(elTop + 8);  // ~middle of first line
                        }

                        var firstLabelMidY = labelMids[0];
                        var lastLabelMidY = labelMids[labelMids.length - 1];
                        var lineColor = group.labels[0].color;

                        // 1. Dot at the table cell edge
                        circle(annotAnchor + 3, rowMid, 3.5, lineColor);

                        // 2. Horizontal from dot to channel
                        line(annotAnchor + 3, rowMid, channelX, rowMid, lineColor, 2);

                        // 3. Vertical stem from row (or where it meets the channel) down through all labels
                        var stemTop = rowMid;
                        var stemBottom = lastLabelMidY;
                        if (stemBottom > stemTop) {
                            line(channelX, stemTop, channelX, stemBottom, lineColor, 2);
                        }

                        // 4. Horizontal tick from stem to each label
                        for (var i = 0; i < labelMids.length; i++) {
                            var tickColor = group.labels[i].color;
                            line(channelX, labelMids[i], labelX - 2, labelMids[i], tickColor, 1.5);
                        }

                        cursor = y + 4;
                    });
                });

                // LTC Payout bracket (cyan, in dark body area)
                if (annotations.ltc_trigger_year && annotations.ltc_payout_end_year) {
                    var bTop = getRowTop(annotations.ltc_trigger_year);
                    var bBottom = getRowBottom(annotations.ltc_payout_end_year);
                    if (bTop !== null && bBottom !== null) {
                        var el = document.createElement('div');
                        el.className = 'annotation-bracket';
                        el.style.top = bTop + 'px';
                        el.style.height = (bBottom - bTop) + 'px';
                        el.style.left = annotLeft + 'px';
                        annotDiv.appendChild(el);

                        // LTC Payout label with ⬐ arrow
                        var ltcLabel = 'LTC Payout';
                        if (annotations.ltc_payout_annual && annotations.ltc_payout_daily) {
                            ltcLabel += ': $' + annotations.ltc_payout_annual.toLocaleString() + '/yr, $' + annotations.ltc_payout_daily.toLocaleString() + '/day';
                        }
                        var ltcLabelEl = document.createElement('div');
                        ltcLabelEl.className = 'annotation-bracket-label';
                        ltcLabelEl.style.top = (bTop - 22) + 'px';
                        ltcLabelEl.style.left = (annotLeft - 12) + 'px';
                        ltcLabelEl.style.width = '300px';
                        ltcLabelEl.style.pointerEvents = 'auto';
                        ltcLabelEl.style.cursor = 'help';
                        ltcLabelEl.title = 'LTC daily payout amount increases by 5% every July 20th, starting at $361 after 7/20/2025. In ' + annotations.ltc_trigger_year + ', it is $' + annotations.ltc_payout_daily.toLocaleString() + '/day.\n\nLTC payout begins when the insurer recognizes the supervision threshold defined in the policy.';
                        var ltcArrow = document.createElement('span');
                        ltcArrow.className = 'bracket-arrow';
                        ltcArrow.textContent = '\u2B10';
                        ltcLabelEl.appendChild(ltcArrow);
                        ltcLabelEl.appendChild(document.createTextNode(ltcLabel + ' \u24D8'));
                        annotDiv.appendChild(ltcLabelEl);

                        // "At-home nursing begins" label above LTC Payout label, with large ⬐ reaching past the smaller arrow
                        if (annotations.ltc_trigger_year) {
                            var nursingLabelEl = document.createElement('div');
                            nursingLabelEl.className = 'annotation-bracket-label';
                            nursingLabelEl.style.top = (bTop - 44) + 'px';
                            nursingLabelEl.style.left = (annotLeft - 36) + 'px';
                            nursingLabelEl.style.width = '300px';
                            nursingLabelEl.style.color = '#cc44aa';
                            var nursingArrow = document.createElement('span');
                            nursingArrow.className = 'bracket-arrow-large';
                            nursingArrow.textContent = '\u2B10';
                            nursingLabelEl.appendChild(nursingArrow);
                            nursingLabelEl.appendChild(document.createTextNode('At-home nursing begins'));
                            annotDiv.appendChild(nursingLabelEl);
                        }
                    }
                }

                // Ensure page is wide enough to scroll to annotations
                var spacer = document.getElementById('annotationSpacer');
                if (!spacer) {
                    spacer = document.createElement('div');
                    spacer.id = 'annotationSpacer';
                    spacer.style.position = 'absolute';
                    spacer.style.top = '0';
                    spacer.style.height = '1px';
                    spacer.style.pointerEvents = 'none';
                    document.body.appendChild(spacer);
                }
                spacer.style.left = '0';
                spacer.style.width = (annotLeft + 340) + 'px';
            }

            if (document.readyState === 'complete') {
                placeAnnotations();
            } else {
                window.addEventListener('load', placeAnnotations);
            }
            window.addEventListener('resize', placeAnnotations);
            // Reposition when param sidebar opens/closes (container width changes)
            document.addEventListener('paramSidebarOpened', function() {
                setTimeout(placeAnnotations, 350); // after CSS transition (300ms)
            });
            // MutationObserver for body class changes (sidebar close removes class)
            new MutationObserver(function(mutations) {
                mutations.forEach(function(m) {
                    if (m.attributeName === 'class') {
                        setTimeout(placeAnnotations, 350);
                    }
                });
            }).observe(document.body, { attributes: true });
        })();
        </script>
        {{/if}}
    {{else}}
        <p style="color: #999;">No projection data available for this scenario.</p>
    {{/if}}
</div>

<div style="margin-top: 40px; margin-bottom: 40px;">
    <h2 style="margin-bottom: 15px; color: #66ccff;">Scenario Decisions <span style="font-size: 14px; color: #888; font-weight: normal;">(protected housing trust remains present across all scenarios)</span></h2>

    {{!-- Non-MAPT scenarios (rental and baseline): HARD BLOCKER red flag at top.
         The protection-trust path is the only one that reuses the existing court-process support property structure
         already needs — every other path requires the same restructuring with
         no offsetting benefit. --}}
    {{#unless (eq scenario.condo_disposition "trust_mapt")}}
    <div style="margin-bottom: 16px; padding: 12px; background: #4a1c1c; border-left: 4px solid #e74c3c; color: #ffcccc; border-radius: 4px;">
        <strong style="color: #ff6666;">⚠ NON-VIABLE WITHOUT STRUCTURAL REWORK</strong>
        <p style="margin: 6px 0 0 0; font-size: 13px;">
            The support property is already held in an <strong>existing protective trust</strong>. Any "no trust" scenario requires:
        </p>
        <ul style="margin: 6px 0 0 18px; font-size: 13px; line-height: 1.5;">
            <li><strong>Formal restructuring</strong> of the existing trust — the same legal work already required by the protected path</li>
            <li>or leaving the support property in fragmented protection while moving other assets, which defeats the planning objective</li>
            <li>or moving the support property into an exposed personal holding pattern, which defeats the original protection purpose</li>
        </ul>
        <p style="margin: 6px 0 0 0; font-size: 13px;">
            <strong>None of these are clean.</strong> This scenario is shown for comparison only — the protected scenarios are the only viable paths because they reuse work the support property already requires.
        </p>
    </div>
    {{/unless}}

    {{!-- 20% down: ORANGE flag for SNT solvency risk --}}
    {{#if (lt (or scenario.mortgage_split_pct 0.80) 0.50)}}
    <div style="margin-bottom: 16px; padding: 12px; background: #4a3618; border-left: 4px solid #f39c12; color: #ffe0b3; border-radius: 4px;">
        <strong style="color: #ffaa44;">⚠ SUPPORT-TRUST SOLVENCY RISK — 20% DOWN PAYMENT</strong>
        <p style="margin: 6px 0 0 0; font-size: 13px;">
            In prior sweeps, 20%-down scenarios have failed to satisfy the private-pay window because the support-property mortgage drag depletes the IRA before the protection window activates. The support trust may be insolvent in late projection years. <strong>Strongly recommend 80% or 100% down.</strong>
        </p>
