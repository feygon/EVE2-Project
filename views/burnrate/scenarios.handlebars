    <div class="container">
        <div class="header-bar">
            <h1>BurnRate Financial Planning</h1>
        </div>

        <div class="scenario-comparison">
            {{> scenario-card disposition="baseline" cardNumber="1" isBaseline=true title="Baseline Runway" subtitle="No structural trust changes. Existing housing plan stays in place and care costs are funded directly."}}
            {{> scenario-card disposition="rental" cardNumber="2" title="No Trust Buffer" subtitle="Legacy condo is rented for household support while the protected condo purchase stays financed through the trust plan."}}
            {{> scenario-card disposition="mapt" cardNumber="3" title="Asset Protection" subtitle="Primary protection path. Housing assets sit inside trust structure with lookback timing and crisis pivot planning."}}
        </div>
    </div>

    {{> burnrate-param-sidebar}}

    <script>
        // Overview: sidebar starts open
        window.sidebarDefaultOpen = true;

        // Inject DB scenario values so sliders initialize from saved state
        window.scenarioData = {};
        {{#each scenarios}}
        window.scenarioData['{{this.id}}'] = {
            ira_growth: {{this.ira_growth}},
            sdira_start: {{or this.sdira_start 68000}},
            managed_ira_start: {{this.managed_ira_start}},
            lifestyle_annual: {{this.lifestyle_annual}},
            primary_appreciation: {{this.primary_appreciation}},
            condo_appreciation: {{this.condo_appreciation}},
            memory_care_inflation: {{this.memory_care_inflation}},
            management_fee: {{this.management_fee}},
            rental_income_monthly: {{this.rental_income_monthly}},
            heloc_rate: {{this.heloc_rate}},
            medical_base_monthly: {{or this.medical_base_monthly 200}},
            memory_care_cost: {{this.memory_care_cost}},
            total_mortgage_amount: {{or this.total_mortgage_amount 0}},
            mortgage_split_pct: {{or this.mortgage_split_pct 0}},
            primary_mortgage_rate: {{or this.primary_mortgage_rate 0}},
            condo_mortgage_rate: {{or this.condo_mortgage_rate 0}},
            condo_maintenance: {{or this.condo_maintenance 0}},
            ltc_trigger_year: {{this.ltc_trigger_year}},
            memory_care_year: {{or this.memory_care_year 2031}},
            year_of_passing: {{or this.year_of_passing 2040}},
            sell_condo_upfront: {{or this.sell_condo_upfront 0}},
            roommate_enabled: {{or this.roommate_enabled 0}},
            roommate_monthly: {{or this.roommate_monthly 1100}},
            primary_house_value: {{or this.primary_house_value 825000}},
            condo_value: {{or this.condo_value 425000}},
            rental_increase_rate: {{or this.rental_increase_rate 0.04}},
            ssdi_monthly: {{or this.ssdi_monthly 3000}},
            lifestyle_floor_monthly: {{or this.lifestyle_floor_monthly 4000}},
            charitable_monthly: {{or this.charitable_monthly 800}},
            snt_seed: {{or this.snt_seed 10000}},
            mc_maintenance_monthly: {{or this.mc_maintenance_monthly 300}},
            mc_residual_monthly: {{or this.mc_residual_monthly 200}},
            optimizer_enabled: {{or this.optimizer_enabled 0}},
            trust_type: '{{or this.trust_type "non_grantor"}}'
        };
        {{/each}}
    </script>
    <script src="/static/js/burnrate-scenarios.js"></script>
