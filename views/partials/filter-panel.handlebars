{{!-- Filter Panel Partial - Reusable filter sidebar for creature comparison tools --}}
<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0"><i class="fas fa-filter"></i> Filters</h5>
    </div>
    <div class="card-body">
        <form id="filterForm">
            {{!-- Keyword Search --}}
            <div class="mb-3">
                <label for="keywordSearch" class="form-label">Search</label>
                <input type="text" class="form-control" id="keywordSearch" name="keyword" placeholder="Name, ability, trait...">
            </div>

            {{!-- Level Filter --}}
            <div class="mb-3">
                <label for="levelFilter" class="form-label">{{levelLabel}}</label>
                <select class="form-select" id="levelFilter" name="level">
                    <option value="">All Levels</option>
                    {{#each (range minLevel maxLevel)}}
                    <option value="{{this}}">Level {{this}}</option>
                    {{/each}}
                </select>
                {{#if levelHelp}}
                <small class="form-text text-muted">{{levelHelp}}</small>
                {{/if}}
            </div>

            {{!-- Trait Filter (multi-select) --}}
            <div class="mb-3">
                <label class="form-label">Traits</label>
                <div id="traitFilterContainer" style="max-height: 240px; overflow-y: auto; border: 1px solid #444; border-radius: 0.375rem; padding: 0.5rem; background-color: #2a2a2a;">
                    {{#if elementalTraits}}
                    <strong class="small d-block mb-1" style="color: #66ccff;">Elemental Traits</strong>
                    {{#each elementalTraits}}
                    <div class="form-check">
                        <input class="form-check-input trait-checkbox" type="checkbox" id="trait-{{this}}" value="{{this}}">
                        <label class="form-check-label small" for="trait-{{this}}">{{this}}</label>
                    </div>
                    {{/each}}
                    {{#if ../creatureTypeTraits}}
                    <hr style="border-color: #555; margin: 0.5rem 0;">
                    <strong class="small d-block mb-1" style="color: #66ccff;">Creature Types</strong>
                    {{#each ../creatureTypeTraits}}
                    <div class="form-check">
                        <input class="form-check-input trait-checkbox" type="checkbox" id="trait-{{this}}" value="{{this}}">
                        <label class="form-check-label small" for="trait-{{this}}">{{this}}</label>
                    </div>
                    {{/each}}
                    {{/if}}
                    {{#if ../rarityTraits}}
                    <hr style="border-color: #555; margin: 0.5rem 0;">
                    <strong class="small d-block mb-1" style="color: #66ccff;">Rarity</strong>
                    {{#each ../rarityTraits}}
                    <div class="form-check">
                        <input class="form-check-input trait-checkbox" type="checkbox" id="trait-{{this}}" value="{{this}}">
                        <label class="form-check-label small" for="trait-{{this}}">{{this}}</label>
                    </div>
                    {{/each}}
                    {{/if}}
                    <hr style="border-color: #555; margin: 0.5rem 0;">
                    <strong class="small d-block mb-1" style="color: #66ccff;">Other Traits</strong>
                    {{#each otherTraits}}
                    <div class="form-check">
                        <input class="form-check-input trait-checkbox" type="checkbox" id="trait-{{this}}" value="{{this}}">
                        <label class="form-check-label small" for="trait-{{this}}">{{this}}</label>
                    </div>
                    {{/each}}
                    {{else}}
                    {{#each traits}}
                    <div class="form-check">
                        <input class="form-check-input trait-checkbox" type="checkbox" id="trait-{{this}}" value="{{this}}">
                        <label class="form-check-label small" for="trait-{{this}}">{{this}}</label>
                    </div>
                    {{/each}}
                    {{/if}}
                </div>
                <small class="form-text text-muted">Select multiple — shows creatures with any checked trait</small>
            </div>

            {{!-- Size Filter --}}
            <div class="mb-3">
                <label for="sizeFilter" class="form-label">Size</label>
                <select class="form-select" id="sizeFilter" name="size">
                    <option value="">All Sizes</option>
                    <option value="Tiny">Tiny</option>
                    <option value="Small">Small</option>
                    <option value="Medium">Medium</option>
                    <option value="Large">Large</option>
                    <option value="Huge">Huge</option>
                    <option value="Gargantuan">Gargantuan</option>
                </select>
            </div>

            {{!-- Movement Filters --}}
            <div class="mb-3">
                <label class="form-label">Movement</label>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="flyingFilter" name="hasFlying">
                    <label class="form-check-label" for="flyingFilter">
                        <i class="fas fa-feather-alt"></i> Can Fly
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="climbingFilter" name="hasClimbing">
                    <label class="form-check-label" for="climbingFilter">
                        <i class="fas fa-hiking"></i> Can Climb
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="burrowingFilter" name="hasBurrowing">
                    <label class="form-check-label" for="burrowingFilter">
                        <i class="fas fa-mountain"></i> Can Burrow
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="swimmingFilter" name="hasSwimming">
                    <label class="form-check-label" for="swimmingFilter">
                        <i class="fas fa-fish"></i> Can Swim
                    </label>
                </div>
            </div>


            <div class="d-grid">
                <button type="reset" class="btn btn-outline-secondary" id="resetFilters">
                    <i class="fas fa-undo"></i> Reset
                </button>
            </div>
        </form>
    </div>
</div>

{{!-- Quick Stats --}}
<div class="card shadow-sm mt-3">
    <div class="card-header">
        <h6 class="mb-0"><i class="fas fa-chart-bar"></i> Current Results</h6>
    </div>
    <div class="card-body">
        <p class="mb-1"><strong id="resultCount">{{creatureCount}}</strong> {{creatureType}}</p>
        <p class="mb-0 text-muted small" id="resultSummary">Showing all creatures</p>
    </div>
</div>
