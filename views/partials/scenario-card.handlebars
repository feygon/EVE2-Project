<!-- Scenario Card Partial -->
<div class="scenario-card" data-scenario-id="" data-disposition="{{disposition}}">
    <div class="card-header">
        <h2>{{title}}</h2>
        <p class="card-subtitle">{{subtitle}}</p>
    </div>

    <div class="timeline-summary" style="padding: 10px; margin: 10px 0; background: #2a2a2a; border-left: 3px solid #66ccff; font-size: 14px; color: #dcdcdc;">
        <strong>Timeline:</strong> <span class="timeline-text">LTC insurance payout in 2028, Memory Care starts 2031, Passing in 2040</span>
    </div>

    <div class="metrics">
        <h3>Financial Metrics (2026-2040)</h3>
        <div class="metric-row">
            <span class="metric-label" title="All liquid assets at start (SDIRA + ManagedIRA + LTC Savings)">Liquid Assets Start:</span>
            <span class="metric-value liquid-assets-start">$643,000</span>
        </div>
        <div class="metric-row">
            <span class="metric-label" title="Liquid assets at end of projection, or year depleted if $0">Liquid Assets Final:</span>
            <span class="metric-value liquid-assets-final">—</span>
        </div>
        <div class="metric-row">
            <span class="metric-label" title="Combined SDIRA + ManagedIRA balance at start">IRA Start:</span>
            <span class="metric-value ira-start">$368,000</span>
        </div>
        <div class="metric-row">
            <span class="metric-label" title="Combined IRA balance at end of projection, or year depleted if $0">IRA Final:</span>
            <span class="metric-value ira-final">—</span>
        </div>
        <div class="metric-row">
            <span class="metric-label" title="Total LTC payouts from trigger year onward">LTC Disbursed:</span>
            <span class="metric-value ltc-total">—</span>
        </div>
        <div class="metric-row mapt-only" style="display:none;">
            <span class="metric-label" title="MAPT checking + SNT balance at end of projection">Trust Balance Final:</span>
            <span class="metric-value trust-balance-final">—</span>
        </div>
        <div class="metric-row">
            <span class="metric-label" title="Final value of all real estate in 2040">Real Estate Final:</span>
            <span class="metric-value real-estate-final">—</span>
        </div>
        <div class="metric-row">
            <span class="metric-label" title="Year and total amount of real estate liquidation needed">Real Estate Liquidated:</span>
            <span class="metric-value real-estate-liquidated">—</span>
        </div>
    </div>

    <div class="card-footer">
        <a href="#" class="btn-details">View Details →</a>
    </div>
</div>
